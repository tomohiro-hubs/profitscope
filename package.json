    "recharts": "2.15.3",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@types/node": "22.15.17",
    "@types/react": "19.1.4",
    "@types/react-dom": "19.1.4",
    "autoprefixer": "10.4.21",
    "eslint": "9.26.0",
    "eslint-config-next": "15.3.2",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3",
    "vitest": "3.1.2",
    "wrangler": "4.24.4"
